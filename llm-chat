#!/usr/bin/env python3
"""Interactive chat REPL for OpenAI-compatible API servers."""

import os

from openai import OpenAI

LLM_API_BASE = os.environ.get("LLM_API_BASE", "http://localhost:8000/v1")
LLM_API_KEY = os.environ.get("LLM_API_KEY", "sk-local-dev")
LLM_MODEL = os.environ.get("LLM_MODEL", "Llama-3.1-8B-Instruct")
LLM_SYSTEM_PROMPT = os.environ.get(
    "LLM_SYSTEM_PROMPT", "You are a helpful assistant."
)

HELP_TEXT = """\
Commands:
  /clear            Clear conversation history
  /model [name]     Show or change the model
  /system [prompt]  Show or change the system prompt
  /help             Show this help
  /quit, /exit      Exit the chat"""


def main():
    from rich.console import Console
    from rich.markdown import Markdown

    console = Console()
    client = OpenAI(base_url=LLM_API_BASE, api_key=LLM_API_KEY)

    model = LLM_MODEL
    system_prompt = LLM_SYSTEM_PROMPT
    messages = []

    console.print(f"[bold]llm-chat[/bold] connected to [cyan]{LLM_API_BASE}[/cyan]")
    console.print(f"Model: [green]{model}[/green]")
    console.print("Type [bold]/help[/bold] for commands, [bold]/quit[/bold] to exit.\n")

    while True:
        try:
            user_input = input("you> ").strip()
        except (EOFError, KeyboardInterrupt):
            console.print("\nBye!")
            break

        if not user_input:
            continue

        # Slash commands
        if user_input.startswith("/"):
            cmd, _, arg = user_input[1:].partition(" ")
            cmd = cmd.lower()
            arg = arg.strip()

            if cmd == "quit" or cmd == "exit":
                console.print("Bye!")
                break
            elif cmd == "help":
                console.print(HELP_TEXT)
            elif cmd == "clear":
                messages.clear()
                console.print("[dim]Conversation cleared.[/dim]")
            elif cmd == "model":
                if arg:
                    model = arg
                    console.print(f"Model set to [green]{model}[/green]")
                else:
                    console.print(f"Model: [green]{model}[/green]")
            elif cmd == "system":
                if arg:
                    system_prompt = arg
                    console.print(f"System prompt set to: [yellow]{system_prompt}[/yellow]")
                else:
                    console.print(f"System prompt: [yellow]{system_prompt}[/yellow]")
            else:
                console.print(f"[red]Unknown command: /{cmd}[/red]")
            continue

        messages.append({"role": "user", "content": user_input})

        request_messages = [{"role": "system", "content": system_prompt}] + messages

        try:
            stream = client.chat.completions.create(
                model=model,
                messages=request_messages,
                stream=True,
            )

            chunks = []
            for chunk in stream:
                if not chunk.choices:
                    continue
                delta = chunk.choices[0].delta
                if delta.content:
                    chunks.append(delta.content)

            response_text = "".join(chunks)
            messages.append({"role": "assistant", "content": response_text})
            console.print()
            console.print(Markdown(response_text))
            console.print()

        except KeyboardInterrupt:
            console.print("\n[dim]Generation interrupted.[/dim]")
            # Remove the unanswered user message
            messages.pop()
        except Exception as e:
            console.print(f"\n[red]Error: {e}[/red]")
            messages.pop()


if __name__ == "__main__":
    main()
